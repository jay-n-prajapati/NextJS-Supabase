# Supabase (required for auth and database)
# Get these from: Supabase Dashboard → Project Settings → API
# https://supabase.com/dashboard/project/_/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://your-project-url.supabase.co
# Publishable key (recommended) — from API Keys → Publishable key. Never use secret/service_role here.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

